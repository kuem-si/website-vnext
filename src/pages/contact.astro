---
import MainLayout from "../layouts/MainLayout.astro";
import LeadForm from "../components/LeadForm.astro";
---
<MainLayout
  title="Contact KUEM"
  description="Send one contact request for partnership, demo, inquiry, or custom subject."
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Talk to KUEM about your deployment priorities.</h1>
      <p>
        Use the form below for partnership, demo, inquiry, or custom requests. Submissions are processed through
        GDPR-aware forms and can be forwarded to Odoo CRM.
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <LeadForm formId="demo-form" heading="Contact request" submitLabel="Send request" sourcePage="contact" />
    </div>
  </section>

  <section>
    <div class="container card">
      <h2>Direct contact</h2>
      <p>Email: <a href="mailto:info@kuem.eu">info@kuem.eu</a></p>
      <p>Phone: <a href="tel:+38659013416">0038659013416</a></p>
      <p>Address: Ljubljanska cesta 24g, 4000 Kranj, Slovenia</p>
    </div>
  </section>
</MainLayout>
