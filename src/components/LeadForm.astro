---
import type { Locale } from "../lib/i18n";

const {
  formType = "demo",
  heading = "Request a demo",
  submitLabel = "Submit request",
  sourcePage = "unknown",
  formId,
  locale = "en"
} = Astro.props;
const statusId = `${formType}-status`;
const apiPath = `${import.meta.env.BASE_URL}api/lead`;
const copy =
  locale === "sl"
    ? {
        fullName: "Polno ime",
        company: "Podjetje",
        role: "Vloga",
        workEmail: "E-posta za delo",
        phone: "Telefon",
        country: "Drzava",
        message: "Sporocilo",
        consent: "Soglasam, da KUEM hrani moje podatke za odgovor na povprasevanje v skladu z GDPR.",
        blocked: "Oddaja je blokirana.",
        submitting: "Posiljanje...",
        success: "Hvala. Kmalu vas bomo kontaktirali.",
        failed: "Oddaja ni uspela. Prosimo, pisite na info@kuem.eu."
      }
    : {
        fullName: "Full name",
        company: "Company",
        role: "Role",
        workEmail: "Work email",
        phone: "Phone",
        country: "Country",
        message: "Message",
        consent: "I consent to KUEM storing my data to respond to this inquiry in line with GDPR.",
        blocked: "Submission blocked.",
        submitting: "Submitting...",
        success: "Thank you. We will contact you shortly.",
        failed: "We could not submit the form. Please email info@kuem.eu."
      };
---
<form class="lead-form" id={formId} data-lead-form data-form-type={formType} data-source-page={sourcePage} data-api-path={apiPath}>
  <h3>{heading}</h3>
  <div class="form-grid">
    <label>
      {copy.fullName}
      <input type="text" name="fullName" required autocomplete="name" />
    </label>
    <label>
      {copy.company}
      <input type="text" name="company" required autocomplete="organization" />
    </label>
    <label>
      {copy.role}
      <input type="text" name="role" required autocomplete="organization-title" />
    </label>
    <label>
      {copy.workEmail}
      <input type="email" name="email" required autocomplete="email" />
    </label>
    <label>
      {copy.phone}
      <input type="tel" name="phone" autocomplete="tel" />
    </label>
    <label>
      {copy.country}
      <input type="text" name="country" autocomplete="country-name" />
    </label>
  </div>
  <label>
    {copy.message}
    <textarea name="message" rows="5" required></textarea>
  </label>
  <input type="text" name="website" tabindex="-1" autocomplete="off" class="hp-field" aria-hidden="true" />
  <label class="consent-check">
    <input type="checkbox" name="consent" value="yes" required />
    {copy.consent}
  </label>
  <button class="btn btn-primary" type="submit">{submitLabel}</button>
  <p id={statusId} class="form-status" role="status" aria-live="polite"></p>
</form>

<script define:vars={{ copy }}>
  const forms = document.querySelectorAll("[data-lead-form]");

  forms.forEach((form) => {
    if (form.dataset.bound === "true") return;
    form.dataset.bound = "true";
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const target = event.currentTarget;
      const status = target.querySelector(".form-status");
      const data = new FormData(target);
      const apiPath = target.dataset.apiPath || "/api/lead";

      if (data.get("website")) {
        if (status) status.textContent = copy.blocked;
        return;
      }

      const payload = {
        leadType: target.dataset.formType,
        sourcePage: target.dataset.sourcePage,
        fullName: String(data.get("fullName") || ""),
        company: String(data.get("company") || ""),
        role: String(data.get("role") || ""),
        email: String(data.get("email") || ""),
        phone: String(data.get("phone") || ""),
        country: String(data.get("country") || ""),
        message: String(data.get("message") || ""),
        consent: data.get("consent") === "yes"
      };

      if (status) status.textContent = copy.submitting;

      try {
        const response = await fetch(apiPath, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result.error || "Request failed");
        }

        if (status) status.textContent = copy.success;
        target.reset();
      } catch (error) {
        if (status) status.textContent = copy.failed;
      }
    });
  });
</script>
